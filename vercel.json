{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.ghost-tax.com" }],
      "destination": "https://ghost-tax.com/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/pulse",
      "schedule": "0 6 * * 1-5"
    },
    {
      "path": "/api/cron/master",
      "schedule": "0 6 * * 0,6"
    }
  ]
}
